<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_lead_followup_wizard_form" model="ir.ui.view">
        <field name="name">lead.followup.wizard.form</field>
        <field name="model">lead.followup.wizard</field>
        <field name="arch" type="xml">
            <form string="Add Follow-Up">
                <sheet>
                    <group>
                        <field name="lead_name" readonly="1"/>
                        <field name="next_followup_date"/>
                        <field name="remarks" placeholder="Follow-up notes..."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_save_followup" string="Save" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
