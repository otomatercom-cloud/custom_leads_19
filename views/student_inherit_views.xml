<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_student_details_form_inherit_lead" model="ir.ui.view">
        <field name="name">student.details.form.inherit.lead</field>
        <field name="model">student.details</field>
        <field name="inherit_id" ref="student_details_19.view_student_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_leads" type="object"
                        class="oe_stat_button" icon="fa-bullhorn"
                        invisible="lead_count == 0">
                    <field name="lead_count" widget="statinfo" string="Leads"/>
                </button>
            </xpath>
            <xpath expr="//field[@name='course_ids']" position="before">
                <field name="lead_id" invisible="1"/>
                <field name="lead_ids" invisible="1"/>
                <field name="lead_count" invisible="1"/>
            </xpath>
        </field>
    </record>
</odoo>
