<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ── Quick Response Wizard (Quality + Response combined) ──────────── -->
    <record id="view_kanban_response_wizard_form" model="ir.ui.view">
        <field name="name">kanban.response.wizard.form</field>
        <field name="model">kanban.response.wizard</field>
        <field name="arch" type="xml">
            <form string="Response &amp; Quality">
                <sheet>

                    <!-- Lead info banner -->
                    <div style="background:linear-gradient(135deg,#1e3a8a,#2563eb);
                                border-radius:12px;padding:12px 16px;margin-bottom:16px;
                                display:flex;justify-content:space-between;align-items:center;">
                        <div>
                            <div style="color:rgba(255,255,255,0.65);font-size:10px;
                                        font-weight:700;letter-spacing:1px;
                                        text-transform:uppercase;">Lead</div>
                            <div style="color:#fff;font-size:16px;font-weight:800;margin:2px 0;">
                                <field name="lead_name" readonly="1" nolabel="1"/>
                            </div>
                            <div style="color:rgba(255,255,255,0.75);font-size:12px;">
                                📱 <field name="phone_number" readonly="1" nolabel="1"/>
                            </div>
                        </div>
                        <div style="background:rgba(255,255,255,0.15);border-radius:8px;
                                    padding:6px 12px;text-align:center;">
                            <div style="color:#bfdbfe;font-size:10px;font-weight:700;">
                                CURRENT</div>
                            <div style="color:#fff;font-size:12px;font-weight:700;">
                                <field name="current_quality" readonly="1" nolabel="1"/>
                            </div>
                        </div>
                    </div>

                    <!-- ① Lead Quality ─────────────────────────────────── -->
                    <div style="margin-bottom:16px;">
                        <div style="font-size:12px;font-weight:800;color:#1e293b;
                                    margin-bottom:8px;display:flex;align-items:center;gap:6px;">
                            <span style="background:#f3e8ff;color:#7c3aed;border-radius:6px;
                                         padding:2px 8px;font-size:11px;">① Lead Quality</span>
                        </div>
                        <field name="new_quality" widget="radio"
                               style="display:grid;grid-template-columns:repeat(2,1fr);
                                      gap:4px 12px;"/>
                    </div>

                    <!-- Divider -->
                    <div style="border-top:2px dashed #e2e8f0;margin:0 0 14px;"/>

                    <!-- ② Response ─────────────────────────────────────── -->
                    <div>
                        <div style="font-size:12px;font-weight:800;color:#1e293b;
                                    margin-bottom:8px;display:flex;align-items:center;gap:6px;">
                            <span style="background:#dbeafe;color:#1d4ed8;border-radius:6px;
                                         padding:2px 8px;font-size:11px;">② Response</span>
                        </div>
                        <field name="response_text" nolabel="1"
                               placeholder="Enter what was discussed, objections, next steps..."
                               style="min-height:90px;width:100%;"/>
                    </div>

                </sheet>
                <footer>
                    <button name="action_save_response" type="object"
                            string="💾 Save" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ── Quick Quality Wizard ──────────────────────────────────────────── -->
    <record id="view_kanban_quality_wizard_form" model="ir.ui.view">
        <field name="name">kanban.quality.wizard.form</field>
        <field name="model">kanban.quality.wizard</field>
        <field name="arch" type="xml">
            <form string="Change Lead Quality">
                <sheet>
                    <!-- Lead banner -->
                    <div style="background:linear-gradient(135deg,#7c3aed,#a855f7);
                                border-radius:12px;padding:12px 16px;margin-bottom:16px;">
                        <div style="color:rgba(255,255,255,0.7);font-size:10px;font-weight:700;
                                    letter-spacing:1px;text-transform:uppercase;">
                            🏷️ Changing Quality For
                        </div>
                        <div style="color:#fff;font-size:16px;font-weight:800;margin:3px 0;">
                            <field name="lead_name" readonly="1" nolabel="1"/>
                        </div>
                        <div style="color:rgba(255,255,255,0.75);font-size:12px;margin-top:2px;">
                            Current:
                            <strong style="color:#e9d5ff;">
                                <field name="current_quality" readonly="1" nolabel="1"/>
                            </strong>
                        </div>
                    </div>

                    <!-- Quality grid selector -->
                    <div style="margin-bottom:12px;">
                        <div style="font-size:11px;color:#64748b;font-weight:700;
                                    text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px;">
                            Select New Quality
                        </div>
                        <field name="new_quality" widget="radio"
                               style="display:grid;grid-template-columns:repeat(2,1fr);gap:6px;"/>
                    </div>

                    <!-- Reason -->
                    <group>
                        <field name="reason" placeholder="Reason for change (optional)"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_update_quality" type="object"
                            string="✅ Update Quality" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ── Call Recording Upload Wizard ─────────────────────────────────── -->
    <record id="view_call_recording_upload_wizard" model="ir.ui.view">
        <field name="name">call.recording.upload.wizard.form</field>
        <field name="model">call.recording.upload.wizard</field>
        <field name="arch" type="xml">
            <form string="Upload Call Recording">
                <sheet>
                    <div style="background:linear-gradient(135deg,#065f46,#059669);
                                border-radius:12px;padding:12px 16px;margin-bottom:16px;">
                        <div style="color:rgba(255,255,255,0.7);font-size:10px;
                                    font-weight:700;letter-spacing:1px;
                                    text-transform:uppercase;">
                            🎙️ Attach Call Recording
                        </div>
                        <div style="color:#fff;font-size:14px;margin-top:4px;">
                            Supported: MP3, WAV, OGG, WebM, M4A, AAC
                        </div>
                    </div>
                    <group>
                        <field name="call_log_id" readonly="1"/>
                        <field name="recording" filename="recording_filename"
                               widget="binary" string="Select Recording File"
                               required="1"/>
                        <field name="recording_filename" string="Filename" readonly="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_upload" type="object"
                            string="📎 Upload &amp; Save" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
