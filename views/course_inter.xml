<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_course_interested_tree" model="ir.ui.view">
        <field name="name">course.interested.tree</field>
        <field name="model">course.interested</field>
        <field name="arch" type="xml">
            <list string="Courses">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_course_interested_form" model="ir.ui.view">
        <field name="name">course.interested.form</field>
        <field name="model">course.interested</field>
        <field name="arch" type="xml">
            <form string="Course Interested">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_course_interested" model="ir.actions.act_window">
        <field name="name">Courses Interested</field>
        <field name="res_model">course.interested</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
