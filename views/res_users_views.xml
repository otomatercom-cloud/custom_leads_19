<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_users_leads_form" model="ir.ui.view">
        <field name="name">res.users.leads.form</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='preferences']" position="after">
                <page string="Call Settings" name="call_settings">
                    <group string="Voxbay">
                        <field name="voxbay_user_no"/>
                    </group>
                    <group string="Bonvoice">
                        <field name="bonvoice_agent_number"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
