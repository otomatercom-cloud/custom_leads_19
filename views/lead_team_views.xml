<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ─── Lead Team Form View ─────────────────────────────────────────── -->
    <record id="view_lead_team_form" model="ir.ui.view">
        <field name="name">lead.team.form</field>
        <field name="model">lead.team</field>
        <field name="arch" type="xml">
            <form string="Lead Team">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Team Name" required="1"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="team_lead_count" string="Team Leads" readonly="1"/>
                            <field name="member_count" string="Admission Officers" readonly="1"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>

                    <field name="description" placeholder="Team description..."/>

                    <notebook>
                        <!-- Tab 1 : Team Leads -->
                        <page string="Team Leads" name="team_leads">
                            <field name="team_lead_ids" nolabel="1">
                                <list string="Team Leads" editable="bottom">
                                    <field name="name"/>
                                    <field name="job_id"/>
                                    <field name="work_phone"/>
                                    <field name="work_email"/>
                                </list>
                            </field>
                        </page>

                        <!-- Tab 2 : Admission Officers -->
                        <page string="Admission Officers" name="members">
                            <field name="member_ids" nolabel="1">
                                <list string="Admission Officers" editable="bottom">
                                    <field name="employee_id" required="1"/>
                                    <field name="team_lead_id"
                                           domain="[('id', 'in', parent.team_lead_ids)]"
                                           options="{'no_create': True}"
                                           string="Reporting To"/>
                                    <field name="user_id" readonly="1" optional="show"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ─── Lead Team List View ─────────────────────────────────────────── -->
    <record id="view_lead_team_list" model="ir.ui.view">
        <field name="name">lead.team.list</field>
        <field name="model">lead.team</field>
        <field name="arch" type="xml">
            <list string="Lead Teams">
                <field name="name"/>
                <field name="team_lead_ids" widget="many2many_tags" string="Team Leads"/>
                <field name="team_lead_count" string="# Leads"/>
                <field name="member_count" string="# Officers"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- ─── Lead Team Search View ───────────────────────────────────────── -->
    <record id="view_lead_team_search" model="ir.ui.view">
        <field name="name">lead.team.search</field>
        <field name="model">lead.team</field>
        <field name="arch" type="xml">
            <search string="Search Teams">
                <field name="name" string="Team Name"/>
                <field name="team_lead_ids" string="Team Lead"/>
                <filter string="Active" name="active" domain="[('active','=',True)]"/>
                <filter string="Archived" name="archived" domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    <!-- ─── Action ──────────────────────────────────────────────────────── -->
    <record id="action_lead_team" model="ir.actions.act_window">
        <field name="name">Teams</field>
        <field name="res_model">lead.team</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_lead_team_search"/>
        <field name="context">{'search_default_active': 1}</field>
    </record>

    <!-- ─── Menu under Configuration ───────────────────────────────────── -->
    <menuitem id="menu_lead_teams"
              name="Teams"
              parent="menu_leads_config"
              action="action_lead_team"
              sequence="5"
              groups="custom_leads_19.group_lead_manager,custom_leads_19.group_super_admin"/>

</odoo>
