<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_voxbay_call_wizard_form" model="ir.ui.view">
        <field name="name">voxbay.call.wizard.form</field>
        <field name="model">voxbay.call.wizard</field>
        <field name="arch" type="xml">
            <form string="Call Status">
                <sheet>
                    <group>
                        <field name="lead_id" readonly="1"/>
                        <field name="phone_number" readonly="1"/>
                        <field name="api_response" readonly="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_completed" string="✅ Completed" type="object" class="btn-success"/>
                    <button name="action_not_answered" string="❌ Not Answered" type="object" class="btn-warning"/>
                    <button name="action_disconnect" string="🔇 Disconnected" type="object" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
