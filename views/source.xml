<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_leads_source_tree" model="ir.ui.view">
        <field name="name">leads.sources.tree</field>
        <field name="model">leads.sources</field>
        <field name="arch" type="xml">
            <list string="Leads Sources">
                <field name="name"/>
                <field name="source"/>
                <field name="digital_lead"/>
            </list>
        </field>
    </record>

    <record id="view_leads_source_form" model="ir.ui.view">
        <field name="name">leads.sources.form</field>
        <field name="model">leads.sources</field>
        <field name="arch" type="xml">
            <form string="Leads Source">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="source"/>
                        <field name="digital_lead"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_leads_source" model="ir.actions.act_window">
        <field name="name">Leads Sources</field>
        <field name="res_model">leads.sources</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
