                        <page string="Call History">
                            <field name="call_log_ids">
                                <list>
                                    <field name="call_time"/>
                                    <field name="user_id"/>
                                    <field name="call_type"/>
                                    <field name="call_status"/>
                                    <field name="duration"/>
                                    <field name="remarks"/>
                                    <field name="has_recording" column_invisible="1"/>
                                    <button name="action_upload_recording" type="object" string="&#128206; Upload Recording" class="btn-sm btn-secondary" invisible="has_recording"/>
                                    <button name="action_upload_recording" type="object" string="&#128260; Replace Recording" class="btn-sm btn-secondary" invisible="not has_recording"/>
                                </list>
                                <form string="Call Log">
                                    <sheet>
                                        <group>
                                            <group>
                                                <field name="call_time"/>
                                                <field name="user_id"/>
                                                <field name="call_type"/>
                                                <field name="duration"/>
                                            </group>
                                            <group>
                                                <field name="call_status"/>
                                                <field name="caller_number"/>
                                                <field name="recording_url" widget="url"/>
                                            </group>
                                        </group>
                                        <group string="Remarks">
                                            <field name="remarks" nolabel="1"/>
                                        </group>
                                        <div invisible="not has_recording" style="margin-top:12px;padding:14px 16px;background:#f0fdf4;border:1px solid #86efac;border-radius:12px;">
                                            <div style="font-size:12px;color:#16a34a;font-weight:700;margin-bottom:8px;">&#127897; Call Recording</div>
                                            <field name="recording" filename="recording_filename" widget="binary" string="Recording File"/>
                                            <div style="margin-top:8px;font-size:11px;color:#64748b;">File: <field name="recording_filename" readonly="1" nolabel="1"/></div>
                                        </div>
                                        <div invisible="has_recording" style="margin-top:12px;padding:14px 16px;background:#fafafa;border:1px dashed #cbd5e1;border-radius:12px;text-align:center;">
                                            <div style="color:#94a3b8;font-size:13px;margin-bottom:10px;">No recording attached yet</div>
                                            <button name="action_upload_recording" type="object" string="&#128206; Upload Recording" class="btn-primary"/>
                                        </div>
                                        <field name="has_recording" invisible="1"/>
                                    </sheet>
                                </form>
                            </field>
                        </page>

                        <page string="Follow-Ups">
                            <field name="followup_ids">
                                <list>
                                    <field name="next_followup_date"/>
                                    <field name="user_id"/>
                                    <field name="remarks"/>
                                    <field name="status"/>
                                    <button name="action_mark_done" string="Mark Done" type="object" invisible="status == 'done'" class="btn-sm btn-success"/>
                                </list>
                            </field>
                        </page>



                        <page string="History">
                            <group string="Assignment History">
                                <field name="assignment_history_ids" readonly="1">
                                    <list>
                                        <field name="assigned_date"/>
                                        <field name="owner_id"/>
                                        <field name="assigned_by"/>
                                    </list>
                                </field>
                            </group>
                            <group string="Quality History">
                                <field name="quality_history_ids" readonly="1">
                                    <list>
                                        <field name="change_date"/>
                                        <field name="lead_quality"/>
                                        <field name="user_id"/>
                                    </list>
                                </field>
                            </group>
                            <group string="Open History">
                                <field name="open_history_ids" readonly="1">
                                    <list>
                                        <field name="opened_on"/>
                                        <field name="user_id"/>
                                        <field name="ip_address"/>
                                        <field name="remarks"/>
                                    </list>
                                </field>
                            </group>
                        </page>

                        <page string="Call Responses">
                            <field name="call_responses" widget="many2many_tags"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ─── Kanban View ────────────────────────────────────────────────── -->
    <record id="view_leads_logic_kanban" model="ir.ui.view">
        <field name="name">leads.logic.kanban</field>
        <field name="model">leads.logic</field>
        <field name="arch" type="xml">
            <kanban default_group_by="lead_quality"
                    default_order="daily_call_done asc, daily_call_sequence asc, id asc"
                    class="o_kanban_small_column o_leads_professional_kanban">
                <field name="name"/>
                <field name="reference_no"/>
                <field name="phone_number"/>
                <field name="masked_phone"/>
                <field name="lead_quality"/>
                <field name="lead_stage_category"/>
                <field name="lead_owner"/>
                <field name="leads_source"/>
                <field name="next_follow_up_date"/>
                <field name="date_of_adding"/>
                <field name="truncated_call_response"/>
                <field name="admission_status"/>
                <field name="daily_call_done"/>
                <field name="daily_call_sequence"/>
                <field name="daily_queue_date"/>
                <field name="daily_call_count"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_global_click o_lead_kanban_card o_lead_kanban_stage_#{record.lead_stage_category.raw_value || 'none'}">
                            <div class="o_lead_kanban_accent"/>

                            <!-- Card Header -->
                            <div class="o_lead_kanban_header">
                                <div class="o_lead_kanban_title_block">
                                    <div class="o_lead_kanban_ref">
                                        <field name="reference_no"/>
                                    </div>
                                    <strong class="o_lead_kanban_name">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <span class="o_lead_kanban_stage">
                                    <field name="lead_stage_category"/>
                                </span>
                            </div>

                            <!-- Quality badge -->
                            <div class="o_lead_kanban_quality">
                                <i class="fa fa-tag"/>
                                <field name="lead_quality"/>
                            </div>

                            <!-- Details -->
                            <div class="o_lead_kanban_details">
                                <div class="o_lead_kanban_detail">
                                    <i class="fa fa-phone"/>
                                    <field name="masked_phone"/>
                                </div>
                                <div class="o_lead_kanban_detail">
                                    <i class="fa fa-bullhorn"/>
                                    <field name="leads_source"/>
                                </div>
                                <div class="o_lead_kanban_detail">
                                    <i class="fa fa-user"/>
                                    <field name="lead_owner"/>
                                </div>
                                <div class="o_lead_kanban_detail" t-if="record.next_follow_up_date.raw_value">
                                    <i class="fa fa-calendar"/>
                                    <field name="next_follow_up_date"/>
                                </div>
                                <div class="o_lead_kanban_detail o_lead_last_response"
                                     t-if="record.truncated_call_response.raw_value">
                                    <i class="fa fa-comment-o"/>
                                    <span t-esc="record.truncated_call_response.raw_value"/>
                                </div>
                            </div>

                            <!-- ─── Quick Action Buttons ─────────────────── -->
                            <div class="o_lead_kanban_quick_actions"
                                 onclick="event.stopPropagation();">
                                <button class="o_lead_quick_btn o_lead_quick_response"
                                        title="Log Response"
                                        type="object" name="action_kanban_quick_response">
                                    <i class="fa fa-comment"/> Response
                                </button>
                                <button class="o_lead_quick_btn o_lead_quick_quality"
                                        title="Change Lead Quality"
                                        type="object" name="action_kanban_quick_quality">
                                    <i class="fa fa-tag"/> Quality
                                </button>
                                <button class="o_lead_quick_btn o_lead_quick_followup"
                                        title="Schedule Follow Up"
                                        type="object" name="action_kanban_quick_followup">
                                    <i class="fa fa-clock-o"/> Follow Up
                                </button>
                            </div>

                            <!-- Daily queue status badge -->
                            <div t-if="record.daily_queue_date.raw_value"
                                 class="o_lead_kanban_queue_status"
                                 onclick="event.stopPropagation();">
                                <span t-if="record.daily_call_done.raw_value == true"
                                      class="o_lead_queue_badge o_lead_queue_done">
                                    <i class="fa fa-check-circle"/> Called today
                                </span>
                                <span t-if="record.daily_call_done.raw_value == false"
                                      class="o_lead_queue_badge o_lead_queue_pending">
                                    <i class="fa fa-circle-o"/> In queue
                                </span>
                            </div>

                            <!-- Footer -->
                            <div class="o_lead_kanban_footer">
                                <span>
                                    <i class="fa fa-clock-o"/>
                                    <field name="date_of_adding"/>
                                </span>
                                <div class="o_lead_kanban_footer_actions">
                                    <button class="o_lead_kanban_call"
                                            onclick="event.stopPropagation();"
                                            type="object" name="action_kanban_start_call"
                                            t-if="record.phone_number.raw_value">
                                        <i class="fa fa-phone"/> Call
                                    </button>
                                    <!-- Mark called and rotate (queue mode) -->
                                    <button class="o_lead_kanban_mark_called"
                                            onclick="event.stopPropagation();"
                                            type="object" name="action_mark_called_rotate"
                                            t-if="record.daily_queue_date.raw_value &amp;&amp; record.daily_call_done.raw_value == false"
                                            title="Mark as called and move to end of queue">
                                        <i class="fa fa-check"/> Done
                                    </button>
                                    <!-- Skip in queue -->
                                    <button class="o_lead_kanban_skip"
                                            onclick="event.stopPropagation();"
                                            type="object" name="action_queue_skip"
                                            t-if="record.daily_queue_date.raw_value &amp;&amp; record.daily_call_done.raw_value == false"
                                            title="Skip — move to end of queue">
                                        <i class="fa fa-forward"/> Skip
                                    </button>
                                    <span class="o_lead_kanban_open">
                                        Open <i class="fa fa-chevron-right"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ─── Search View ────────────────────────────────────────────────── -->
    <record id="view_leads_logic_search" model="ir.ui.view">
        <field name="name">leads.logic.search</field>
        <field name="model">leads.logic</field>
        <field name="arch" type="xml">
            <search string="Leads">
                <field name="name"/>
                <field name="phone_number"/>
                <field name="leads_source"/>
                <field name="lead_owner"/>
                <field name="team_id" string="Team"/>
                <field name="lead_creator_id"/>
                <field name="tele_caller_id"/>
                <filter string="My Created Leads" name="filter_my_created_leads"
                        domain="[('lead_creator_id', '=', uid)]"/>
                <!-- ── Daily Queue Filters ──────────────────────────────── -->
                <filter string="Today's Queue" name="filter_today_queue"
                        domain="[('daily_queue_date', '=', context_today())]"/>
                <filter string="Uncalled First" name="uncalled_first"
                        domain="[('daily_call_done', '=', False), ('daily_queue_date', '=', context_today())]"/>
                <filter string="Called Today" name="filter_called_today"
                        domain="[('daily_call_done', '=', True), ('daily_queue_date', '=', context_today())]"/>
                <filter string="My Queue Today" name="filter_my_queue_today"
                        domain="[('daily_queue_date', '=', context_today())]"/>
                <separator/>
                <group>
                    <filter string="Team" name="group_team"
                            context="{'group_by': 'team_id'}"/>
                    <filter string="Lead Creator" name="group_lead_creator"
                            context="{'group_by': 'lead_creator_id'}"/>
                    <filter string="Lead Quality" name="group_lead_quality"
                            context="{'group_by': 'lead_quality'}"/>
                    <filter string="Queue Status" name="group_queue_status"
                            context="{'group_by': 'daily_call_done'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ─── Action ────────────────────────────────────────────────────── -->
    <record id="action_leads_logic" model="ir.actions.act_window">
        <field name="name">Leads</field>
        <field name="res_model">leads.logic</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_leads_logic_search"/>
        <field name="context">{'search_default_filter_my': 0}</field>
    </record>

