                            <span style="background:#dcfce7;color:#166534;border-radius:6px;padding:2px 8px;">&#127979; Admission Details</span>
                        </div>
                        <group col="4">
                            <field name="admission_batch" string="Batch"/>
                            <field name="admission_branch" string="Branch"/>
                            <field name="admission_course" string="Course"/>
                            <field name="student_name"/>
                            <field name="student_id" readonly="1"/>
                            <field name="student_profile_created"/>
                            <field name="receipt_no"/>
                            <field name="admission_amount"/>
                            <field name="date_of_receipt"/>
                            <field name="admission_fee_paid"/>
                        </group>
                    </div> -->

                    <!-- Sales Guide -->
                    <!--<div invisible="hide_marketing_stages" class="o_field_widget" style="width:100%;overflow-x:auto;margin-bottom:16px;">
                        <div style="font-weight:700;font-size:13px;color:#555;margin-bottom:4px;">SALES GUIDE</div>
                        <field name="progress_html" widget="html" readonly="1" nolabel="1"/>
                    </div>-->

                    <!-- NOTEBOOK -->
                    <notebook>
                     <!--   <page string="Touch Points">
