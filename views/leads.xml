<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ─── List View ─────────────────────────────────────────────────── -->
    <record id="view_leads_logic_tree" model="ir.ui.view">
        <field name="name">leads.logic.list</field>
        <field name="model">leads.logic</field>
        <field name="arch" type="xml">
            <list string="Leads" default_order="id desc"
                  decoration-danger="lead_quality in ['not_responding','not_reachable','not_attended','wrong_number','not_interested']"
                  decoration-success="lead_quality in ['admission','waiting_for_admission','already_joined']"
                  decoration-warning="lead_quality in ['hot','warm']">
                <field name="reference_no" optional="show"/>
                <field name="name"/>
                <field name="masked_phone" string="Mobile"/>
                <field name="course_inter" widget="many2many_tags" string="Course Interested" optional="show"/>
                <field name="leads_source" optional="show"/>
                <field name="lead_quality"/>
                <field name="call_response" string="Last Response" optional="show"/>
                <field name="attendance_percentage" string="Attend %" optional="show"/>
                <field name="lead_stage_category" optional="show"/>
                <field name="lead_owner"/>
                <field name="team_id" optional="show" string="Team"/>
                <field name="lead_creator_id" optional="show"/>
                <field name="next_follow_up_date" optional="show"/>
                <field name="date_of_adding" optional="show"/>
                <field name="last_update_date" optional="show"/>
                <field name="company_id" groups="base.group_multi_company" optional="show"/>
            </list>
        </field>
    </record>

    <!-- ─── Form View ─────────────────────────────────────────────────── -->
    <record id="view_leads_logic_form" model="ir.ui.view">
        <field name="name">leads.logic.form</field>
        <field name="model">leads.logic</field>
        <field name="arch" type="xml">
            <form string="Lead" class="o_leads_phone_form">
                <!-- Status Bar -->
                <header class="o_lead_form_header">
                    <button name="act_attempt_to_connect" string="🎯 First Attempt" type="object"
                            class="btn-primary" invisible="state != 'new'"/>
                    <button name="act_connected" string="✅ Connected" type="object"
                            class="btn-success" invisible="state == 'qualified'"/>
                    <button name="act_not_connected" string="📵 Not Connected" type="object"
                            class="btn-warning" invisible="state == 'qualified'"/>
                    <!--<button name="action_voxbay_call" string="📞 Voxbay Call" type="object"/>
                    <button name="action_bonvoice_call" string="📞 BV Call" type="object"/>
                    <button name="action_open_funnel_wizard" string="🔵 Funnel" type="object"/>-->
                    <button name="action_open_confirm_wizard" string="👁 Open Lead" type="object"/>
                    <button name="action_add_followup" string="⏰ Follow Up" type="object"/>
                    <button name="action_add_call_log" string="📋 Log Call" type="object"/>
                    <button name="act_lost_lead" string="❌ Lost" type="object"
                            class="btn-danger" invisible="state == 'lost'"/>
                    <button name="action_open_convert_wizard" string="Convert" type="object"
                            class="btn-primary"
                            invisible="lead_quality in ['admission','waiting_for_admission'] or student_profile_created"/>
                    <button name="action_open_admission_wizard" string="Admission" type="object"
                            class="btn-success"
                            invisible="student_profile_created or lead_quality not in ['waiting_for_admission','hot','warm']"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="new,in_progress,qualified,lost"/>
                </header>

                <sheet>
                    <!-- Smart Buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_student" type="object" class="oe_stat_button" icon="fa-graduation-cap"
                                invisible="not student_id">
                            <field name="student_id" widget="statinfo" string="Student"/>
                        </button>
                        <button name="whatsapp_click_button" type="object" class="oe_stat_button" icon="fa-whatsapp">
                            <span>WhatsApp</span>
                        </button>
                        <button name="action_open_webinar_wizard" type="object" class="oe_stat_button" icon="fa-video-camera">
                            <span>Webinar</span>
                        </button>
                        <button name="action_toggle_phone" type="object" class="oe_stat_button" icon="fa-eye">
                            <span>Show Phone</span>
                        </button>
                        <button name="action_toggle_marketing_info" type="object" class="oe_stat_button" icon="fa-bar-chart">
                            <field name="marketing_button_label"/>
                        </button>
                    </div>

                    <!-- Lead Title -->
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Lead Name"/></h1>
                    </div>

                    <!-- Date Strip -->
                    <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:18px;padding:10px 14px;background:#f0f4ff;border-radius:10px;border:1px solid #d0daf5;">
                        <div style="display:flex;align-items:center;gap:6px;background:#fff;border:1px solid #c5d0ee;border-radius:6px;padding:5px 12px;">
                            <i class="fa fa-calendar-plus-o" style="color:#7c8ec7;font-size:13px;"/>
                            <span style="font-size:11px;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Added</span>
                            <field name="date_of_adding" readonly="1" nolabel="1"/>
                        </div>
                        <div style="display:flex;align-items:center;gap:6px;background:#fff;border:1px solid #c5d0ee;border-radius:6px;padding:5px 12px;">
                            <i class="fa fa-refresh" style="color:#7c8ec7;font-size:13px;"/>
                            <span style="font-size:11px;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Updated</span>
                            <field name="last_update_date" readonly="1" nolabel="1"/>
                        </div>
                        <div style="display:flex;align-items:center;gap:6px;background:#fff;border:1px solid #c5d0ee;border-radius:6px;padding:5px 12px;">
                            <i class="fa fa-user-plus" style="color:#7c8ec7;font-size:13px;"/>
                            <span style="font-size:11px;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Assigned</span>
                            <field name="assigned_date" readonly="1" nolabel="1"/>
                        </div>
                        <div style="display:flex;align-items:center;gap:6px;background:#fff;border:1px solid #ffd0a0;border-radius:6px;padding:5px 12px;">
                            <i class="fa fa-bell" style="color:#f0a030;font-size:13px;"/>
                            <span style="font-size:11px;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Next Follow Up</span>
                            <field name="next_follow_up_date" readonly="1" nolabel="1"/>
                        </div>
                    </div>

                    <!-- ROW 1: Contact + Assignment -->
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
                        <div style="background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:16px;box-shadow:0 1px 4px rgba(0,0,0,0.06);">
                            <div style="font-size:11px;font-weight:800;color:#64748b;text-transform:uppercase;letter-spacing:1px;margin-bottom:12px;">
                                <span style="background:#dbeafe;color:#1d4ed8;border-radius:6px;padding:2px 8px;">&#128222; Contact Info</span>
                            </div>
                            <group col="2">
                                <field name="reference_no" readonly="1"/>
                                <field name="leads_source"/>
                                <field name="phone_number"/>
                                <field name="masked_phone" string="Masked Phone" readonly="1"/>
                                <field name="phone_number_second"/>
                                <field name="parent_number"/>
                                <field name="email_address"/>
                            </group>
                        </div>
                        <div style="background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:16px;box-shadow:0 1px 4px rgba(0,0,0,0.06);">
                            <div style="font-size:11px;font-weight:800;color:#64748b;text-transform:uppercase;letter-spacing:1px;margin-bottom:12px;">
                                <span style="background:#dcfce7;color:#15803d;border-radius:6px;padding:2px 8px;">&#128100; Assignment</span>
                            </div>
                            <group col="2">
                                <field name="lead_creator_id" readonly="1"/>
                                <field name="lead_owner"/>
                                <field name="team_id" readonly="1" string="Team"/>
                                <field name="tele_caller_id"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                                <field name="lead_quality"/>
                                <field name="attendance_percentage" string="Attendance %"/>
                                <field name="lead_stage_category" readonly="1"/>
                                <field name="admission_status"/>
                                <field name="admission_date" invisible="not admission_status"/>
                            </group>
                        </div>
                    </div>

                    <!-- ROW 2: Course Interest + Latest Response -->
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
                        <div style="background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:16px;box-shadow:0 1px 4px rgba(0,0,0,0.06);">
                            <div style="font-size:11px;font-weight:800;color:#64748b;text-transform:uppercase;letter-spacing:1px;margin-bottom:12px;">
                                <span style="background:#fef3c7;color:#92400e;border-radius:6px;padding:2px 8px;">&#127891; Course Interest</span>
                            </div>
                            <group col="2">
                                <field name="course_inter" widget="many2many_tags" nolabel="1" colspan="2"/>
                                <field name="academic_year_of_course_attend"/>
                                <field name="academic_year"/>
                                <field name="batch_preference"/>
                                <field name="district"/>
                                <field name="country"/>
                                <field name="place"/>
                                <field name="college_name"/>
                                <field name="stream"/>
                            </group>
                        </div>
                        <div style="background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:16px;box-shadow:0 1px 4px rgba(0,0,0,0.06);">
                            <div style="font-size:11px;font-weight:800;color:#64748b;text-transform:uppercase;letter-spacing:1px;margin-bottom:12px;display:flex;justify-content:space-between;align-items:center;">
                                <span style="background:#f3e8ff;color:#7c3aed;border-radius:6px;padding:2px 8px;">&#128172; Responses</span>
                            </div>
                            <!-- Response cards list -->
                            <field name="response_ids" nolabel="1">
                                <list editable="bottom" string="Responses">
                                    <field name="response_time" readonly="1" string="Time"/>
                                    <field name="user_id" readonly="1" string="By"/>
                                    <field name="comment" string="Response"/>
                                    <field name="is_editable" invisible="1" column_invisible="1"/>
                                    <button name="action_enable_edit" string="Edit" type="object"
                                            invisible="is_editable" class="btn-sm"/>
                                </list>
                            </field>
                            <field name="not_response_note" invisible="lead_quality not in ['not_responding','not_reachable']"/>
                            <field name="lost_reason" invisible="state != 'lost'"/>
                        </div>
                    </div>

                    <!-- ROW 3: Source/Campaign + Referral 
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
                        <div style="background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:16px;box-shadow:0 1px 4px rgba(0,0,0,0.06);">
