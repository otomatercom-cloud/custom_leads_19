<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ─── Today's Queue action — officer sees only their own leads ─────── -->
    <record id="action_my_daily_queue" model="ir.actions.act_window">
        <field name="name">My Queue Today</field>
        <field name="res_model">leads.logic</field>
        <field name="view_mode">kanban,list</field>
        <field name="domain">[
            ('daily_queue_date', '=', context_today()),
            ('lead_owner.user_id', '=', uid)
        ]</field>
        <field name="context">{
            'default_order': 'daily_call_done asc, daily_call_sequence asc, daily_queue_priority asc, id asc'
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Your queue for today is empty.
            </p>
            <p>
                Go to <b>Settings → Technical → Scheduled Actions</b> and run
                <b>"Leads: Rebuild Daily Queue Each Morning"</b> manually to populate today's queue.
            </p>
        </field>
    </record>

    <!-- ─── All officer queues — manager/team lead view ─────────────────── -->
    <record id="action_leads_today_queue" model="ir.actions.act_window">
        <field name="name">All Officer Queues</field>
        <field name="res_model">leads.logic</field>
        <field name="view_mode">kanban,list</field>
        <field name="domain">[('daily_queue_date', '=', context_today())]</field>
        <field name="context">{
            'default_order': 'daily_call_done asc, daily_call_sequence asc, id asc'
        }</field>
    </record>

