<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_lead_bulk_assign_wizard_form" model="ir.ui.view">
        <field name="name">lead.bulk.assign.wizard.form</field>
        <field name="model">lead.bulk.assign.wizard</field>
        <field name="arch" type="xml">
            <form string="Bulk Assign Leads">
                <sheet>
                    <div class="alert alert-info" role="alert" style="margin-bottom:16px;">
                        <i class="fa fa-info-circle" style="margin-right:6px;"/>
                        <strong>
                            <field name="lead_count" readonly="1" nolabel="1"/>
                            lead(s) selected.
                        </strong>
                        Choose an owner below and click <em>Assign</em>.
                    </div>
                    <group>
                        <field name="new_owner_id"
                               string="Assign To (Owner)"
                               options="{'no_create': True}"
                               placeholder="Select an employee…"/>
                    </group>
                    <field name="lead_ids" invisible="1"/>
                </sheet>
                <footer>
                    <button name="action_bulk_assign"
                            string="✅ Assign"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Server action shown in list view Actions menu -->
    <record id="action_lead_bulk_assign_server" model="ir.actions.server">
        <field name="name">Bulk Assign Owner</field>
        <field name="model_id" ref="custom_leads_19.model_leads_logic"/>
        <field name="binding_model_id" ref="custom_leads_19.model_leads_logic"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
action = env['lead.bulk.assign.wizard'].with_context(active_ids=records.ids).action_open_wizard()
        </field>
    </record>
</odoo>
