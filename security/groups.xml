<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data noupdate="0">

        <!-- Step 1: Create the Category -->
        <record id="module_category_lead_management" model="ir.module.category">
            <field name="name">Lead Management</field>
            <field name="sequence">20</field>
        </record>

        <!-- Step 2: Create a Privilege (NEW in Odoo 19) -->
        <record id="res_groups_privilege_lead_management" model="res.groups.privilege">
            <field name="name">Lead Management</field>
            <field name="sequence">10</field>
            <field name="category_id" ref="module_category_lead_management"/>
        </record>

        <!-- Step 3: Groups now use privilege_id instead of category_id -->
        <record id="group_lead_team_lead" model="res.groups">
            <field name="name">Team Lead</field>
            <field name="privilege_id" ref="res_groups_privilege_lead_management"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_lead_tele_callers" model="res.groups">
            <field name="name">Tele Callers</field>
            <field name="privilege_id" ref="res_groups_privilege_lead_management"/>
