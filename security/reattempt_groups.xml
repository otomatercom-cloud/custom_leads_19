<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="0">

        <!-- Re-Attempt User (Admission Officers) -->
        <record id="group_reattempt_user" model="res.groups">
            <field name="name">Re-Attempt User</field>
            <field name="privilege_id" ref="res_groups_privilege_lead_management"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Re-Attempt Team Lead -->
        <record id="group_reattempt_teamlead" model="res.groups">
            <field name="name">Re-Attempt Team Lead</field>
            <field name="privilege_id" ref="res_groups_privilege_lead_management"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user')),
                                             (4, ref('custom_leads_19.group_reattempt_user'))]"/>
        </record>

        <!-- Re-Attempt Manager (Full Access) -->
        <record id="group_reattempt_manager" model="res.groups">
            <field name="name">Re-Attempt Manager</field>
            <field name="privilege_id" ref="res_groups_privilege_lead_management"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user')),
                                             (4, ref('custom_leads_19.group_reattempt_teamlead'))]"/>
        </record>

    </data>
</odoo>
